    {
      "name": "M-Pesa (Daraja)",
      "item": [
        {
          "name": "Initiate STK Push (M-Pesa)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"STK Push initiated successfully\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.have.property('success', true);",
                  "    pm.expect(pm.response.json()).to.have.property('checkout_request_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{mpesaPhone}}\",\n  \"amount\": 10,\n  \"order_id\": {{orderId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mpesa/stk-push",
              "host": ["{{baseUrl}}"],
              "path": ["mpesa", "stk-push"]
            },
            "description": "Triggers real M-Pesa STK Push (sandbox: phone 254708374149, PIN 254708)"
          }
        }
      ],
      "description": "Real M-Pesa Daraja STK Push integration"
    }
  ]
