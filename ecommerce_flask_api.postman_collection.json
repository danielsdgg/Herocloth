{
  "info": {
    "_postman_id": "e-commerce-flask-updated",
    "name": "E-commerce Flask API (Updated)",
    "description": "Postman collection for testing Flask e-commerce backend APIs - with M-Pesa Daraja STK Push support",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT access token (from /auth/login)"
    },
    {
      "key": "productId",
      "value": "1",
      "type": "string",
      "description": "Product ID for testing reviews/orders"
    },
    {
      "key": "orderId",
      "value": "1",
      "type": "string",
      "description": "Order ID for testing (update after creating)"
    },
    {
      "key": "darajaConsumerKey",
      "value": "your_consumer_key_here",
      "type": "string",
      "description": "Daraja API Consumer Key (sandbox or production)"
    },
    {
      "key": "darajaConsumerSecret",
      "value": "your_consumer_secret_here",
      "type": "string",
      "description": "Daraja API Consumer Secret"
    },
    {
      "key": "mpesaPhone",
      "value": "254708374149",
      "type": "string",
      "description": "Test phone for STK Push (sandbox: 254708374149)"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstname\": \"John\", \"lastname\": \"Doe\", \"email\": \"john.doe@example.com\", \"phone\": 1234567890, \"password\": \"password123\", \"role\": \"user\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstname\": \"Admin\", \"lastname\": \"User\", \"email\": \"admin@example.com\", \"phone\": 9876543210, \"password\": \"admin123\", \"role\": \"admin\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json()).to.have.property('access_token');",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"john.doe@example.com\", \"password\": \"password123\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "User",
