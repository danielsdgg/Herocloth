    {
      "name": "M-Pesa (Daraja)",
      "item": [
        {
          "name": "Initiate STK Push (M-Pesa)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"STK Push response is valid\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success', true);",
                  "    pm.expect(jsonData).to.have.property('checkout_request_id');",
                  "    pm.expect(jsonData.message).to.include('check your phone');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{mpesaPhone}}\",\n  \"amount\": 10,\n  \"order_id\": {{orderId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mpesa/stk-push",
              "host": ["{{baseUrl}}"],
              "path": ["mpesa", "stk-push"]
            }
          }
        },
        {
          "name": "Get Access Token (Manual Test)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Basic {{darajaConsumerKey}}:{{darajaConsumerSecret}}"
              }
            ],
            "url": {
              "raw": "https://sandbox.safaricom.co.ke/oauth/v1/generate?grant_type=client_credentials",
              "host": ["sandbox.safaricom.co.ke"],
              "path": ["oauth", "v1", "generate"],
              "query": [
                {
                  "key": "grant_type",
                  "value": "client_credentials"
                }
              ]
            }
          }
        },
        {
          "name": "Simulate STK Push Callback (Webhook Test)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Body\": {\n    \"stkCallback\": {\n      \"MerchantRequestID\": \"12345-abc\",\n      \"CheckoutRequestID\": \"ws_CO_DMZ_123456789\",\n      \"ResultCode\": 0,\n      \"ResultDesc\": \"The service request is processed successfully.\",\n      \"CallbackMetadata\": {\n        \"Item\": [\n          { \"Name\": \"Amount\", \"Value\": 10 },\n          { \"Name\": \"MpesaReceiptNumber\", \"Value\": \"RKF12345678\" },\n          { \"Name\": \"TransactionDate\", \"Value\": 20260209143000 },\n          { \"Name\": \"PhoneNumber\", \"Value\": 254708374149 }\n        ]\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/mpesa/callback",
              "host": ["{{baseUrl}}"],
              "path": ["mpesa", "callback"]
            }
          }
        }
      ]
    },
