    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{productId}},\n  \"rating\": 5,\n  \"comment\": \"Great quality and fast delivery!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/review/",
              "host": ["{{baseUrl}}"],
              "path": ["review", ""]
            }
          }
        },
        {
          "name": "Get Rating Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/review/product/{{productId}}/rating-summary",
              "host": ["{{baseUrl}}"],
              "path": ["review", "product", "{{productId}}", "rating-summary"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (Prepay + M-Pesa + Nairobi)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_method\": \"mpesa\",\n  \"payment_timing\": \"prepay\",\n  \"delivery_option\": \"nairobi\",\n  \"mpesa_phone\": \"{{mpesaPhone}}\",\n  \"street\": \"Ngong Road\",\n  \"city\": \"Nairobi\",\n  \"county\": \"Nairobi\",\n  \"postal_code\": \"00100\",\n  \"instructions\": \"Leave at gate\",\n  \"contact_phone\": \"{{mpesaPhone}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/order/create",
              "host": ["{{baseUrl}}"],
              "path": ["order", "create"]
            },
            "description": "Creates prepay order with M-Pesa and Nairobi delivery (fee 200 added)"
          }
        },
