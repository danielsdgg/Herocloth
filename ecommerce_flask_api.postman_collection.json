              "raw": "{\"role\": \"admin\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/user/2",
              "host": ["{{baseUrl}}"],
              "path": ["user", "2"]
            }
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
