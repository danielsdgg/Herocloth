                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user/2",
              "host": ["{{baseUrl}}"],
              "path": ["user", "2"]
            }
          }
        }
      ]
    },
    {
      "name": "Product",
